---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Contact — SeedSystems™"
  description="Get in touch with SeedSystems™. Enterprise enquiries, partnership discussions, and early access sign-ups."
>
  <section class="contact-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">SeedSystems™</a>
        <span class="crumb-sep">→</span>
        <span>Contact</span>
      </div>
      <div class="gold-rule"></div>
      <p class="section-label">Get in Touch</p>
      <h1 class="contact-h1">
        Let's talk about<br />
        <em>your problem.</em>
      </h1>
      <p class="contact-sub">
        Whether you're enquiring about enterprise deployment, early access to an
        upcoming sector, or a partnership discussion — send us a note.
        We respond within one business day.
      </p>
    </div>
  </section>

  <section class="contact-options">
    <div class="container">
      <div class="options-grid">
        <div class="option-card">
          <div class="option-label">Enterprise Enquiry</div>
          <div class="option-title">Tier 4–7 Deployment</div>
          <div class="option-desc">
            Full system deployment, institutional setup, or managed operations.
            We'll scope the engagement and send a proposal within 48 hours.
          </div>
          <a href="mailto:hello@seedsystems.co?subject=Enterprise Enquiry" class="btn-primary">
            Start conversation
          </a>
        </div>
        <div class="option-card">
          <div class="option-label">Early Access</div>
          <div class="option-title">Upcoming Sectors</div>
          <div class="option-desc">
            Be first when Enterprise, Health, Legal or Finance systems launch.
            Sector-specific notification. No noise.
          </div>
          <a href="mailto:hello@seedsystems.co?subject=Early Access" class="btn-ghost">
            Join early access
          </a>
        </div>
        <div class="option-card">
          <div class="option-label">Partnership</div>
          <div class="option-title">Build with Us</div>
          <div class="option-desc">
            Reseller, distribution, or co-build discussions. If you have access to
            a sector we haven't built yet, we want to hear from you.
          </div>
          <a href="mailto:hello@seedsystems.co?subject=Partnership" class="btn-ghost">
            Talk partnerships
          </a>
        </div>
      </div>
      <div class="contact-direct">
        <p class="contact-email-label">Direct email</p>
        <a href="mailto:hello@seedsystems.co" class="contact-email">hello@seedsystems.co</a>
        <p class="contact-email-note">For any enquiry not covered above.</p>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-hero {
    padding: 80px 0 80px;
    background: var(--canvas);
    border-bottom: 1px solid var(--rule);
  }
  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; color: var(--ink-light); letter-spacing: 0.04em;
    margin-bottom: 40px; font-family: var(--sans);
  }
  .breadcrumb a { color: var(--ink-light); text-decoration: none; transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--ink); }
  .crumb-sep { color: var(--rule); }
  .contact-h1 {
    font-family: var(--serif);
    font-size: clamp(40px, 6vw, 76px); font-weight: 300; line-height: 1.06;
    color: var(--ink); margin-bottom: 24px;
  }
  .contact-h1 em { font-style: italic; color: var(--gold-dark); }
  .contact-sub {
    font-size: 16px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.75; max-width: 560px;
  }
  .contact-options { padding: 100px 0; background: var(--canvas-2); }
  .options-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: var(--rule); border: 1px solid var(--rule);
    overflow: hidden; margin-bottom: 64px;
  }
  .option-card { background: var(--white); padding: 36px; display: flex; flex-direction: column; gap: 0; }
  .option-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--gold-dark); margin-bottom: 10px; font-family: var(--sans);
  }
  .option-title {
    font-family: var(--serif); font-size: 20px; font-weight: 300; color: var(--ink);
    margin-bottom: 12px;
  }
  .option-desc {
    font-size: 13px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.65; margin-bottom: 28px; flex: 1;
  }
  .contact-direct {
    padding-top: 48px; border-top: 1px solid var(--rule);
    text-align: center;
  }
  .contact-email-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold-dark); margin-bottom: 10px;
    font-family: var(--sans);
  }
  .contact-email {
    display: block; font-family: var(--serif);
    font-size: 28px; font-weight: 300; color: var(--ink);
    text-decoration: none; margin-bottom: 8px;
    transition: color 0.2s;
  }
  .contact-email:hover { color: var(--gold-dark); }
  .contact-email-note { font-size: 12px; font-weight: 300; color: var(--ink-light); }

  .btn-primary {
    background: var(--ink); color: var(--canvas);
    font-size: 11px; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 13px 24px;
    text-decoration: none; display: inline-block;
    transition: opacity 0.2s; font-family: var(--sans);
    align-self: flex-start;
  }
  .btn-primary:hover { opacity: 0.75; }
  .btn-ghost {
    border: 1px solid var(--rule); color: var(--ink-mid);
    font-size: 11px; padding: 13px 24px; text-decoration: none;
    display: inline-block; font-family: var(--sans);
    transition: border-color 0.2s, color 0.2s; align-self: flex-start;
  }
  .btn-ghost:hover { border-color: var(--ink); color: var(--ink); }

  @media (max-width: 768px) {
    .options-grid { grid-template-columns: 1fr; }
  }
</style>
