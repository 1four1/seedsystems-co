---
import PageLayout from '../../../layouts/PageLayout.astro';
import CTABlock from '../../../components/CTABlock.astro';

const tiers = [
  {
    n: 'T1', label: 'Free Diagnostic Pack', price: 'Free',
    desc: 'The Subject Diagnostic prompt — understand exactly where you\'re losing marks in 20 minutes. No email required.',
    cta: 'Download free', href: 'https://seedsystems.gumroad.com/l/freealelvelstudyguide', live: true,
  },
  {
    n: 'T2', label: 'Templates Bundle', price: '£29 (~$37)',
    desc: 'Revision planner template, mark scheme analysis sheet, and technique drill tracker.',
    cta: 'Get templates', href: 'https://seedsystems.gumroad.com/l/alevel-t2-templates', live: true,
  },
  {
    n: 'T3', label: 'The Workflow System', price: '£49 (~$62)',
    desc: 'The complete session-by-session workflow. Run the full system across 30 days with zero ambiguity.',
    cta: 'Get the workflow', href: 'https://seedsystems.gumroad.com/l/alevel-t3-workflows', live: true,
  },
  {
    n: 'T4', label: 'The Full System', price: '£97 (~$122)',
    desc: 'Every module. 6 core prompts. 30-day protocol. Spaced repetition engine. Full Paper Debrief. The complete blueprint.',
    cta: 'Get the full system', href: 'https://seedsystems.gumroad.com/l/ALevelgradegapsystem', live: true,
  },
  {
    n: 'T5', label: 'StudySystems SaaS', price: 'From £19/mo (~$24)',
    desc: 'The system running live at mystudysystem.ai. Progress saved. Spaced repetition managed. AI coach on Pro.',
    cta: 'Join waitlist', href: 'https://mystudysystem.ai', live: false,
  },
];

const modules = [
  {
    n: 'Module 1', label: 'Subject Diagnostic',
    prompt: 'P1 — Subject Diagnostic',
    desc: 'Identifies exactly where marks are being lost — by assessment objective (AO1/AO2/AO3) and topic cluster. Works across all A-Level subjects and exam boards.',
  },
  {
    n: 'Module 2', label: 'Question Decoder',
    prompt: 'P2 — Question Decoder',
    desc: 'Breaks down any exam question by command word, assessment objective split, and ideal answer structure. No more misreading what the question actually wants.',
  },
  {
    n: 'Module 3', label: 'Active Recall Generator',
    prompt: 'P3 — Active Recall Generator',
    desc: 'Generates 15 AO-weighted recall questions per topic. Built on evidence-based spaced repetition principles.',
  },
  {
    n: 'Module 4', label: 'Technique Drill Generator',
    prompt: 'P4 — Technique Drill Generator',
    desc: 'Isolates the exact technique causing mark loss and generates targeted micro-drills. The fastest path from knowing to performing.',
  },
  {
    n: 'Module 5', label: 'Session Planner',
    prompt: 'P5 — Session Planner',
    desc: 'Builds a personalised 30-day study protocol with interleaved topics, priority weighting, and spaced repetition intervals.',
  },
  {
    n: 'Module 6', label: 'Full Paper Debrief',
    prompt: 'P6 — Full Paper Debrief',
    desc: 'After any past paper — feeds the results back in, diagnoses technique vs knowledge gaps, and adjusts the protocol accordingly.',
  },
];

const proofPoints = [
  { n: '97%', l: 'Accuracy rate across 18 test scenarios at launch QA' },
  { n: '5.2×', l: 'Conservative value multiple vs purchase price' },
  { n: '22 min', l: 'To complete Module 1 as a naive Year 13 student' },
  { n: '12/12', l: 'Ethics clearance questions passed' },
];
---

<PageLayout
  title="The A-Level Grade Gap System — SeedSystems™ Education"
  description="Close the gap between your current grade and your target A-Level grade. 6 subject-specific AI prompts, a 30-day revision protocol, and a Full Paper Debrief system. Works across all subjects and exam boards."
  activePath="/education/"
>
  <!-- ── PAGE HERO ── -->
  <section class="product-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">SeedSystems™</a>
        <span class="crumb-sep">→</span>
        <a href="/education/">Education</a>
        <span class="crumb-sep">→</span>
        <span>A-Level Grade Gap System</span>
      </div>
      <div class="product-hero-inner">
        <div class="hero-left">
          <div class="product-ids">
            <span class="product-id-chip">SS-EDU-001</span>
            <span class="tag tag-gold">Live</span>
          </div>
          <div class="product-tier-label">Tier 4 System — Full Operating Blueprint</div>
          <h1 class="product-hero-h1">
            The A-Level<br />
            <em>Grade Gap System</em>
          </h1>
          <p class="product-hero-sub">
            Close the gap between your current grade and your target grade.
            Subject-specific diagnostics, technique drills, and a 30-day revision
            protocol — built for Year 12 and 13 students across all A-Level subjects
            and exam boards.
          </p>
          <div class="product-hero-actions">
            <a href="https://seedsystems.gumroad.com/l/ALevelgradegapsystem" class="btn-primary">Get the full system — £97 (~$122)</a>
            <a href="#free" class="btn-ghost">Download free diagnostic ↓</a>
          </div>
          <div class="product-proof-strip">
            {proofPoints.map(p => (
              <div class="proof-item">
                <span class="proof-n">{p.n}</span>
                <span class="proof-l">{p.l}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="hero-right">
          <div class="product-spec-card">
            <div class="spec-label">Product Specification</div>
            <div class="spec-row"><span>Product ID</span><span>SS-EDU-001</span></div>
            <div class="spec-row"><span>Sector</span><span>Education</span></div>
            <div class="spec-row"><span>Tier</span><span>T4 — Full System</span></div>
            <div class="spec-row"><span>Target user</span><span>UK A-Level, Y12–Y13</span></div>
            <div class="spec-row"><span>Secondary market</span><span>GCC A-Level students</span></div>
            <div class="spec-row"><span>Exam boards</span><span>AQA, Edexcel, OCR, WJEC</span></div>
            <div class="spec-row"><span>Core prompts</span><span>6 modules</span></div>
            <div class="spec-row"><span>Protocol length</span><span>30 days</span></div>
            <div class="spec-row"><span>Ethics clearance</span><span>12/12 PASS</span></div>
            <div class="spec-row"><span>Version</span><span>v1.0</span></div>
            <div class="spec-divider"></div>
            <a href="https://seedsystems.gumroad.com/l/ALevelgradegapsystem" class="spec-cta btn-primary">Get this system — £97 (~$122)</a>
            <div class="spec-free">
              <a href="#free">Free T1 diagnostic available below →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROBLEM ── -->
  <section class="problem-section">
    <div class="container">
      <div class="problem-inner">
        <div class="gold-rule"></div>
        <p class="section-label">The Problem</p>
        <h2 class="section-h2">
          The gap isn't a knowledge problem.<br />
          <em>It's a technique problem.</em>
        </h2>
        <div class="problem-body">
          <p>
            Most A-Level students who fall short of their target grade aren't missing content.
            They're losing marks on technique — misreading command words, writing descriptively
            when the mark scheme rewards analysis, failing to apply AO3 evaluation where it's
            required.
          </p>
          <p>
            Revision guides, past papers, and tutors can fill knowledge gaps. None of them
            systematically diagnose technique gaps, isolate the exact skill causing mark loss,
            and build a targeted drill protocol to fix it. The Grade Gap System does.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── MODULES ── -->
  <section class="modules-section">
    <div class="container">
      <div class="modules-intro">
        <p class="section-label">The System Architecture</p>
        <h2 class="section-h2">
          6 prompts. 30 days.<br /><em>One grade boundary crossed.</em>
        </h2>
        <p class="section-body">
          Each module targets a specific part of the grade gap. Run them in sequence,
          or use them independently. The system adapts to any subject and any exam board.
        </p>
      </div>
      <div class="modules-grid">
        {modules.map((m, i) => (
          <div class="module-card" class:list={[{ 'module-featured': i === 0 }]}>
            <div class="module-header">
              <span class="module-n">{m.n}</span>
              <span class="module-prompt">{m.prompt}</span>
            </div>
            <h3 class="module-title">{m.label}</h3>
            <p class="module-desc">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TIERS ── -->
  <section class="tiers-section" id="free">
    <div class="container">
      <p class="section-label">Entry Points</p>
      <h2 class="section-h2">
        Start free.<br /><em>Upgrade when you're ready.</em>
      </h2>
      <p class="section-body">
        Tier 1 is free — no email required. The full system is Tier 4. The SaaS platform (Tier 5)
        is coming. Enter wherever makes sense and the system pulls you forward.
      </p>
      <div class="tiers-list">
        {tiers.map(t => (
          <div class:list={['tier-item', { 'tier-live': t.live }]}>
            <div class="tier-n-tag">{t.n}</div>
            <div class="tier-body">
              <div class="tier-label">{t.label}</div>
              <div class="tier-desc">{t.desc}</div>
            </div>
            <div class="tier-right">
              <div class="tier-price">{t.price}</div>
              <a
                href={t.href}
                class:list={['tier-cta', t.live ? 'btn-primary' : 'btn-ghost tier-disabled']}
                aria-disabled={!t.live}
              >
                {t.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ETHICS ── -->
  <section class="ethics-section">
    <div class="container ethics-inner">
      <div class="gold-rule"></div>
      <p class="section-label">Ethics Clearance</p>
      <h2 class="section-h2">
        Built for students.<br /><em>Ethics-cleared before launch.</em>
      </h2>
      <p class="section-body" style="margin-bottom: 40px;">
        Every SeedSystems™ Education product passes a 12-point AI Ethics Checklist before shipping.
        This product is designed to support — not replace — independent learning. It augments
        student effort; it doesn't do the work for them.
      </p>
      <div class="ethics-cards">
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">Supports independent learning — does not write answers for students</div>
        </div>
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">No personal data required at Tier 1–4</div>
        </div>
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">Accuracy-tested across 18 subject/board scenarios before launch</div>
        </div>
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">OCR/WJEC caveat documented — users instructed to cross-reference spec</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <CTABlock
    eyebrow="Your next grade boundary"
    headline="The full system.<br /><em>£97. One-time.</em>"
    subtext="6 core prompts, a 30-day protocol, spaced repetition engine, and full paper debrief. Works across all A-Level subjects. Every exam board."
    primaryLabel="Get the A-Level Grade Gap System — £97"
    primaryHref="https://seedsystems.gumroad.com/l/ALevelgradegapsystem"
    ghostLabel="Download free T1 diagnostic"
    ghostHref="https://seedsystems.gumroad.com/l/freealelvelstudyguide"
  />

  <!-- ── AFFILIATE ── -->
  <section class="affiliate-section">
    <div class="container">
      <div class="affiliate-inner">
        <div class="gold-rule"></div>
        <p class="section-label">Affiliate Programme</p>
        <h2 class="section-h2">
          Recommend the system.<br />
          <em>Earn on every sale.</em>
        </h2>
        <p class="affiliate-body">
          If you're a tutor, teacher, content creator, or student with an audience — the
          SeedSystems™ affiliate programme lets you earn commission on every sale you refer.
          No minimums. No lock-ins. Apply in under two minutes.
        </p>
        <div class="affiliate-points">
          <div class="ap-item">
            <span class="ap-icon">→</span>
            <span>Competitive commission on every tier — T1 through T4</span>
          </div>
          <div class="ap-item">
            <span class="ap-icon">→</span>
            <span>Tracked via Gumroad — payouts direct to your account</span>
          </div>
          <div class="ap-item">
            <span class="ap-icon">→</span>
            <span>Works for tutors, revision YouTubers, student influencers, and schools</span>
          </div>
        </div>
        <a href="https://seedsystems.gumroad.com/affiliates" class="btn-primary affiliate-cta" target="_blank" rel="noopener">
          Apply to the affiliate programme →
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  /* ── PRODUCT HERO ── */
  .product-hero {
    padding: 72px 0 80px;
    background: var(--canvas);
    border-bottom: 1px solid var(--rule);
  }
  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; color: var(--ink-light); letter-spacing: 0.04em;
    margin-bottom: 40px; font-family: var(--sans);
  }
  .breadcrumb a { color: var(--ink-light); text-decoration: none; transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--ink); }
  .crumb-sep { color: var(--rule); }

  .product-hero-inner {
    display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: start;
  }
  .hero-left { max-width: 620px; }
  .product-ids {
    display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
  }
  .product-id-chip {
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-light); font-family: var(--sans);
  }
  .tag { display: inline-block; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; font-family: var(--sans); }
  .tag-gold { background: var(--gold); color: var(--ink); }

  .product-tier-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold-dark); margin-bottom: 20px;
    font-family: var(--sans);
  }
  .product-hero-h1 {
    font-family: var(--serif);
    font-size: clamp(40px, 5.5vw, 72px); font-weight: 300; line-height: 1.06;
    color: var(--ink); margin-bottom: 24px;
  }
  .product-hero-h1 em { font-style: italic; color: var(--gold-dark); }
  .product-hero-sub {
    font-size: 16px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.75; margin-bottom: 40px;
  }
  .product-hero-actions {
    display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px;
  }
  .product-proof-strip {
    display: flex; gap: 32px; flex-wrap: wrap;
    padding-top: 32px; border-top: 1px solid var(--rule);
  }
  .proof-item { display: flex; flex-direction: column; gap: 4px; }
  .proof-n { font-family: var(--serif); font-size: 26px; font-weight: 300; color: var(--ink); }
  .proof-l { font-size: 11px; font-weight: 300; color: var(--ink-light); line-height: 1.5; max-width: 140px; }

  /* Spec card */
  .product-spec-card {
    background: var(--canvas-2); border: 1px solid var(--rule);
    padding: 28px; min-width: 260px;
  }
  .spec-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold-dark); margin-bottom: 20px; font-family: var(--sans);
  }
  .spec-row {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 12px; padding: 8px 0; border-bottom: 1px solid var(--rule);
    gap: 16px;
  }
  .spec-row span:first-child { color: var(--ink-light); font-weight: 300; white-space: nowrap; }
  .spec-row span:last-child  { color: var(--ink); font-weight: 400; text-align: right; }
  .spec-divider { height: 20px; }
  .spec-cta { display: block; text-align: center; margin-bottom: 14px; }
  .spec-free { text-align: center; }
  .spec-free a {
    font-size: 11px; color: var(--gold-dark); text-decoration: none;
    font-family: var(--sans); transition: color 0.2s;
  }
  .spec-free a:hover { color: var(--ink); }

  /* ── PROBLEM ── */
  .problem-section { padding: 100px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .problem-inner { max-width: 760px; }
  .problem-body { display: flex; flex-direction: column; gap: 20px; margin-top: 0; }
  .problem-body p { font-size: 16px; font-weight: 300; color: var(--ink-mid); line-height: 1.8; }

  /* ── MODULES ── */
  .modules-section { padding: 100px 0; background: var(--canvas); border-bottom: 1px solid var(--rule); }
  .modules-intro { margin-bottom: 56px; }
  .modules-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); overflow: hidden; }
  .module-card { background: var(--white); padding: 32px; }
  .module-card.module-featured { background: var(--canvas-2); }
  .module-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .module-n { font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-dark); font-family: var(--sans); }
  .module-prompt { font-size: 10px; font-weight: 400; color: var(--ink-light); letter-spacing: 0.04em; font-family: var(--sans); }
  .module-title { font-family: var(--serif); font-size: 20px; font-weight: 300; color: var(--ink); margin-bottom: 12px; }
  .module-desc { font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.65; }

  /* ── TIERS ── */
  .tiers-section { padding: 100px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .tiers-list { margin-top: 56px; border-top: 1px solid var(--rule); }
  .tier-item {
    display: grid; grid-template-columns: 60px 1fr auto;
    gap: 24px; align-items: center;
    padding: 28px 0; border-bottom: 1px solid var(--rule);
    transition: background 0.15s;
  }
  .tier-item.tier-live { background: var(--gold-dim); padding: 28px 20px; margin: 0 -20px; }
  .tier-n-tag { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold-dark); font-family: var(--sans); }
  .tier-label { font-size: 15px; font-weight: 400; color: var(--ink); margin-bottom: 4px; }
  .tier-desc { font-size: 12px; font-weight: 300; color: var(--ink-mid); line-height: 1.6; max-width: 480px; }
  .tier-right { text-align: right; display: flex; flex-direction: column; gap: 12px; align-items: flex-end; }
  .tier-price { font-family: var(--serif); font-size: 22px; font-weight: 300; color: var(--ink); }
  .tier-cta { padding: 10px 20px; font-size: 11px; }
  .tier-disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

  /* ── ETHICS ── */
  .ethics-section { padding: 100px 0; background: var(--canvas); border-bottom: 1px solid var(--rule); }
  .ethics-inner { max-width: 800px; }
  .ethics-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); overflow: hidden; margin-top: 40px; }
  .ethics-card { display: flex; gap: 14px; padding: 24px; background: var(--white); }
  .ec-icon { font-size: 16px; color: var(--gold-dark); flex-shrink: 0; margin-top: 1px; }
  .ec-label { font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.6; }

  /* ── Buttons ── */
  .btn-primary {
    background: var(--ink); color: var(--canvas);
    font-size: 11px; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 14px 28px;
    text-decoration: none; display: inline-block;
    transition: opacity 0.2s; font-family: var(--sans);
  }
  .btn-primary:hover { opacity: 0.75; }
  .btn-ghost {
    border: 1px solid var(--rule); color: var(--ink-mid);
    font-size: 11px; padding: 14px 28px; text-decoration: none;
    display: inline-block; font-family: var(--sans);
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--ink); color: var(--ink); }

  /* ── AFFILIATE ── */
  .affiliate-section { padding: 100px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .affiliate-inner { max-width: 760px; }
  .affiliate-body {
    font-size: 16px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.8; margin-bottom: 40px;
  }
  .affiliate-points {
    display: flex; flex-direction: column; gap: 16px;
    margin-bottom: 40px; padding: 32px;
    background: var(--canvas); border: 1px solid var(--rule);
  }
  .ap-item {
    display: flex; gap: 14px; align-items: baseline;
    font-size: 14px; font-weight: 300; color: var(--ink-mid); line-height: 1.6;
  }
  .ap-icon { color: var(--gold-dark); font-family: var(--sans); flex-shrink: 0; }
  .affiliate-cta { display: inline-block; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .product-hero-inner { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    .modules-grid { grid-template-columns: repeat(2, 1fr); }
    .tier-item { grid-template-columns: 50px 1fr; }
    .tier-right { display: none; }
  }
  @media (max-width: 640px) {
    .modules-grid { grid-template-columns: 1fr; }
    .ethics-cards { grid-template-columns: 1fr; }
    .product-proof-strip { gap: 20px; }
  }
</style>
