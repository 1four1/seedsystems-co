---
import PageLayout from '../../../layouts/PageLayout.astro';
import CTABlock from '../../../components/CTABlock.astro';

const tiers = [
  {
    n: 'T1', label: 'IB Grade Gap Finder', price: 'Free',
    desc: 'The IB diagnostic prompt pack — map exactly where your scores are being lost across subjects, IA, and the core. No email required.',
    cta: 'Download free', href: '#free', live: true,
  },
  {
    n: 'T2', label: 'Templates Bundle', price: '£29',
    desc: 'IB System Planner, Revision Architecture template, Core Component Tracker, and Score Tracker spreadsheet.',
    cta: 'Get templates', href: 'https://gumroad.com', live: true,
  },
  {
    n: 'T3', label: 'The SOPs', price: '£49',
    desc: 'Step-by-step operating procedures for every pillar of the Diploma — from IA drafting workflow to TOK exhibition sequencing.',
    cta: 'Get the SOPs', href: 'https://gumroad.com', live: true,
  },
  {
    n: 'T4', label: 'The Full System', price: '£97',
    desc: 'All 6 pillars. Complete IA Mastery Framework. EE + TOK architecture. 30-day revision protocol. Navigator Dashboard. The complete IB blueprint.',
    cta: 'Get the full system', href: 'https://gumroad.com', live: true,
  },
  {
    n: 'T5', label: 'StudySystems SaaS', price: 'From £19/mo',
    desc: 'The IB Study System running live at mystudysystem.ai. Progress tracked. AI coach adapts to your subject combination. Spaced repetition managed.',
    cta: 'Join waitlist', href: 'https://mystudysystem.ai', live: false,
  },
];

const pillars = [
  {
    n: 'Pillar 1', label: 'The IB System Map',
    prompt: 'P1 — System Map',
    desc: 'Navigate the full 2-year Diploma architecture. Understand how subjects, IA, EE, TOK, and CAS interact — and where the highest-leverage score gains are for your specific combination.',
  },
  {
    n: 'Pillar 2', label: 'Subject Strategy',
    prompt: 'P2 — Subject Strategy',
    desc: 'HL and SL mark scheme logic, assessment objective breakdowns, and subject-specific technique gaps. Covers all six subject groups with command term mastery built in.',
  },
  {
    n: 'Pillar 3', label: 'IA Mastery Framework',
    prompt: 'P3 — IA Mastery',
    desc: 'Internal Assessment planning, drafting, and iteration system. Criterion-by-criterion diagnostic. Covers all IA types — from Group 4 investigations to Language A commentary.',
  },
  {
    n: 'Pillar 4', label: 'EE + TOK System',
    prompt: 'P4 — EE + TOK',
    desc: 'Extended Essay architecture from research question to final draft. TOK essay and exhibition framework mapped to the knowledge questions rubric. The bonus 3 points, systematised.',
  },
  {
    n: 'Pillar 5', label: 'Revision Architecture',
    prompt: 'P5 — Revision Architecture',
    desc: '30-day structured revision protocol with interleaved subject rotation, spaced repetition intervals, and paper debrief cycles. Calibrated to May and November exam sessions.',
  },
  {
    n: 'Pillar 6', label: 'Predicted Grade Strategy',
    prompt: 'P6 — Predicted Grade',
    desc: 'Maximise predicted grades for university applications. Understand how IB coordinators assess predicted scores and position your coursework and class performance accordingly.',
  },
];

const proofPoints = [
  { n: '225K', l: 'IB Diploma candidates per year, growing 4–7% YoY' },
  { n: '6', l: 'System pillars covering every component of the Diploma' },
  { n: '12/12', l: 'Ethics clearance questions passed before launch' },
  { n: 'First', l: 'Whole-system IB product — no subject-only limitation' },
];
---

<PageLayout
  title="The IB Study System — IB Decoded — SeedSystems™ Education"
  description="The complete architecture for navigating the IB Diploma. Subject strategy, IA mastery, EE + TOK system, and a 30-day revision protocol — built for IB Diploma students worldwide."
  activePath="/education/"
>
  <!-- ── PAGE HERO ── -->
  <section class="product-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">SeedSystems™</a>
        <span class="crumb-sep">→</span>
        <a href="/education/">Education</a>
        <span class="crumb-sep">→</span>
        <span>IB Study System</span>
      </div>
      <div class="product-hero-inner">
        <div class="hero-left">
          <div class="product-ids">
            <span class="product-id-chip">SS-EDU-002</span>
            <span class="tag tag-gold">Live</span>
          </div>
          <div class="product-tier-label">Tier 4 System — Full Operating Blueprint</div>
          <h1 class="product-hero-h1">
            The IB Study System.<br />
            <em>IB Decoded.</em>
          </h1>
          <p class="product-hero-sub">
            The first product to address the IB Diploma as a complete navigable system.
            Subject strategy, IA mastery, EE + TOK architecture, and a structured 30-day
            revision protocol — built for Diploma students across every subject combination,
            every session, every school.
          </p>
          <div class="product-hero-actions">
            <a href="https://gumroad.com" class="btn-primary">Get the full system — £97</a>
            <a href="#free" class="btn-ghost">Download free diagnostic ↓</a>
          </div>
          <div class="product-proof-strip">
            {proofPoints.map(p => (
              <div class="proof-item">
                <span class="proof-n">{p.n}</span>
                <span class="proof-l">{p.l}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="hero-right">
          <div class="product-spec-card">
            <div class="spec-label">Product Specification</div>
            <div class="spec-row"><span>Product ID</span><span>SS-EDU-002</span></div>
            <div class="spec-row"><span>Sector</span><span>Education</span></div>
            <div class="spec-row"><span>Tier</span><span>T4 — Full System</span></div>
            <div class="spec-row"><span>Target user</span><span>IB Diploma, Y12–Y13</span></div>
            <div class="spec-row"><span>Secondary market</span><span>International schools globally</span></div>
            <div class="spec-row"><span>Sessions</span><span>May + November</span></div>
            <div class="spec-row"><span>System pillars</span><span>6 pillars</span></div>
            <div class="spec-row"><span>Protocol length</span><span>30 days</span></div>
            <div class="spec-row"><span>Ethics clearance</span><span>12/12 PASS</span></div>
            <div class="spec-row"><span>Version</span><span>v1.0</span></div>
            <div class="spec-divider"></div>
            <a href="https://gumroad.com" class="spec-cta btn-primary">Get this system — £97</a>
            <div class="spec-free">
              <a href="#free">Free T1 diagnostic available below →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROBLEM ── -->
  <section class="problem-section">
    <div class="container">
      <div class="problem-inner">
        <div class="gold-rule"></div>
        <p class="section-label">The Problem</p>
        <h2 class="section-h2">
          The IB isn't hard because the content is hard.<br />
          <em>It's hard because no one explains the system.</em>
        </h2>
        <div class="problem-body">
          <p>
            IB students fail to hit their target scores not because they lack knowledge —
            but because the Diploma is a multi-component system with interdependent
            assessment structures that no single textbook, tutoring service, or revision
            platform maps in full. IA, EE, TOK, subject exams, and predicted grades all
            interact. Most students navigate this blind.
          </p>
          <p>
            Every existing IB resource is subject-specific. Revision Village covers Maths.
            OSC covers individual subjects. Nothing addresses the Diploma as a whole —
            as a navigable system with a strategy. The IB Study System does. Six pillars.
            Every component mapped. One architecture for the full two-year journey.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PILLARS ── -->
  <section class="modules-section">
    <div class="container">
      <div class="modules-intro">
        <p class="section-label">The System Architecture</p>
        <h2 class="section-h2">
          6 pillars. Every component.<br /><em>One architecture.</em>
        </h2>
        <p class="section-body">
          Each pillar addresses a distinct area of the Diploma where scores are won or lost.
          Run them in sequence across two years, or deploy individual pillars wherever
          you need leverage most. Built for every subject combination, both sessions.
        </p>
      </div>
      <div class="modules-grid">
        {pillars.map((p, i) => (
          <div class="module-card" class:list={[{ 'module-featured': i === 0 }]}>
            <div class="module-header">
              <span class="module-n">{p.n}</span>
              <span class="module-prompt">{p.prompt}</span>
            </div>
            <h3 class="module-title">{p.label}</h3>
            <p class="module-desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TIERS ── -->
  <section class="tiers-section" id="free">
    <div class="container">
      <p class="section-label">Entry Points</p>
      <h2 class="section-h2">
        Start free.<br /><em>Upgrade when you're ready.</em>
      </h2>
      <p class="section-body">
        Tier 1 is free — no email required. The full 6-pillar system is Tier 4 at £97.
        The SaaS platform (Tier 5) is in build at mystudysystem.ai. Enter at any tier
        and the architecture pulls you forward.
      </p>
      <div class="tiers-list">
        {tiers.map(t => (
          <div class:list={['tier-item', { 'tier-live': t.live }]}>
            <div class="tier-n-tag">{t.n}</div>
            <div class="tier-body">
              <div class="tier-label">{t.label}</div>
              <div class="tier-desc">{t.desc}</div>
            </div>
            <div class="tier-right">
              <div class="tier-price">{t.price}</div>
              <a
                href={t.href}
                class:list={['tier-cta', t.live ? 'btn-primary' : 'btn-ghost tier-disabled']}
                aria-disabled={!t.live}
              >
                {t.cta}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── ETHICS ── -->
  <section class="ethics-section">
    <div class="container ethics-inner">
      <div class="gold-rule"></div>
      <p class="section-label">Ethics Clearance</p>
      <h2 class="section-h2">
        Built for students.<br /><em>Ethics-cleared before launch.</em>
      </h2>
      <p class="section-body" style="margin-bottom: 40px;">
        Every SeedSystems™ Education product passes a 12-point AI Ethics Checklist before shipping.
        This product supports independent thinking — it does not write your IA, EE, or essays.
        It gives you the architecture to do the work yourself, better.
      </p>
      <div class="ethics-cards">
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">Supports independent work — does not write IA, EE, or TOK essays for students</div>
        </div>
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">No personal data required at Tier 1–4</div>
        </div>
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">Not affiliated with or endorsed by the IB Organisation (IBO)</div>
        </div>
        <div class="ethics-card">
          <div class="ec-icon">✓</div>
          <div class="ec-label">Results vary by student — no guaranteed grade outcomes are claimed</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <CTABlock
    eyebrow="The IB Diploma, finally decoded"
    headline="The full system.<br /><em>£97. One-time.</em>"
    subtext="6 pillars. IA mastery framework. EE + TOK architecture. 30-day revision protocol. Navigator Dashboard. Works across every subject combination, both sessions."
    primaryLabel="Get the IB Study System"
    primaryHref="https://gumroad.com"
    ghostLabel="Download free T1 diagnostic"
    ghostHref="#free"
  />
</PageLayout>

<style>
  /* ── PRODUCT HERO ── */
  .product-hero {
    padding: 72px 0 80px;
    background: var(--canvas);
    border-bottom: 1px solid var(--rule);
  }
  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; color: var(--ink-light); letter-spacing: 0.04em;
    margin-bottom: 40px; font-family: var(--sans);
  }
  .breadcrumb a { color: var(--ink-light); text-decoration: none; transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--ink); }
  .crumb-sep { color: var(--rule); }

  .product-hero-inner {
    display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: start;
  }
  .hero-left { max-width: 620px; }
  .product-ids {
    display: flex; align-items: center; gap: 10px; margin-bottom: 10px;
  }
  .product-id-chip {
    font-size: 10px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--ink-light); font-family: var(--sans);
  }
  .tag { display: inline-block; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; font-family: var(--sans); }
  .tag-gold { background: var(--gold); color: var(--ink); }

  .product-tier-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold-dark); margin-bottom: 20px;
    font-family: var(--sans);
  }
  .product-hero-h1 {
    font-family: var(--serif);
    font-size: clamp(40px, 5.5vw, 72px); font-weight: 300; line-height: 1.06;
    color: var(--ink); margin-bottom: 24px;
  }
  .product-hero-h1 em { font-style: italic; color: var(--gold-dark); }
  .product-hero-sub {
    font-size: 16px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.75; margin-bottom: 40px;
  }
  .product-hero-actions {
    display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px;
  }
  .product-proof-strip {
    display: flex; gap: 32px; flex-wrap: wrap;
    padding-top: 32px; border-top: 1px solid var(--rule);
  }
  .proof-item { display: flex; flex-direction: column; gap: 4px; }
  .proof-n { font-family: var(--serif); font-size: 26px; font-weight: 300; color: var(--ink); }
  .proof-l { font-size: 11px; font-weight: 300; color: var(--ink-light); line-height: 1.5; max-width: 140px; }

  /* Spec card */
  .product-spec-card {
    background: var(--canvas-2); border: 1px solid var(--rule);
    padding: 28px; min-width: 260px;
  }
  .spec-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold-dark); margin-bottom: 20px; font-family: var(--sans);
  }
  .spec-row {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 12px; padding: 8px 0; border-bottom: 1px solid var(--rule);
    gap: 16px;
  }
  .spec-row span:first-child { color: var(--ink-light); font-weight: 300; white-space: nowrap; }
  .spec-row span:last-child  { color: var(--ink); font-weight: 400; text-align: right; }
  .spec-divider { height: 20px; }
  .spec-cta { display: block; text-align: center; margin-bottom: 14px; }
  .spec-free { text-align: center; }
  .spec-free a {
    font-size: 11px; color: var(--gold-dark); text-decoration: none;
    font-family: var(--sans); transition: color 0.2s;
  }
  .spec-free a:hover { color: var(--ink); }

  /* ── PROBLEM ── */
  .problem-section { padding: 100px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .problem-inner { max-width: 760px; }
  .problem-body { display: flex; flex-direction: column; gap: 20px; margin-top: 0; }
  .problem-body p { font-size: 16px; font-weight: 300; color: var(--ink-mid); line-height: 1.8; }

  /* ── PILLARS ── */
  .modules-section { padding: 100px 0; background: var(--canvas); border-bottom: 1px solid var(--rule); }
  .modules-intro { margin-bottom: 56px; }
  .modules-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); overflow: hidden; }
  .module-card { background: var(--white); padding: 32px; }
  .module-card.module-featured { background: var(--canvas-2); }
  .module-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .module-n { font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold-dark); font-family: var(--sans); }
  .module-prompt { font-size: 10px; font-weight: 400; color: var(--ink-light); letter-spacing: 0.04em; font-family: var(--sans); }
  .module-title { font-family: var(--serif); font-size: 20px; font-weight: 300; color: var(--ink); margin-bottom: 12px; }
  .module-desc { font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.65; }

  /* ── TIERS ── */
  .tiers-section { padding: 100px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .tiers-list { margin-top: 56px; border-top: 1px solid var(--rule); }
  .tier-item {
    display: grid; grid-template-columns: 60px 1fr auto;
    gap: 24px; align-items: center;
    padding: 28px 0; border-bottom: 1px solid var(--rule);
    transition: background 0.15s;
  }
  .tier-item.tier-live { background: var(--gold-dim); padding: 28px 20px; margin: 0 -20px; }
  .tier-n-tag { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold-dark); font-family: var(--sans); }
  .tier-label { font-size: 15px; font-weight: 400; color: var(--ink); margin-bottom: 4px; }
  .tier-desc { font-size: 12px; font-weight: 300; color: var(--ink-mid); line-height: 1.6; max-width: 480px; }
  .tier-right { text-align: right; display: flex; flex-direction: column; gap: 12px; align-items: flex-end; }
  .tier-price { font-family: var(--serif); font-size: 22px; font-weight: 300; color: var(--ink); }
  .tier-cta { padding: 10px 20px; font-size: 11px; }
  .tier-disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

  /* ── ETHICS ── */
  .ethics-section { padding: 100px 0; background: var(--canvas); border-bottom: 1px solid var(--rule); }
  .ethics-inner { max-width: 800px; }
  .ethics-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); overflow: hidden; margin-top: 40px; }
  .ethics-card { display: flex; gap: 14px; padding: 24px; background: var(--white); }
  .ec-icon { font-size: 16px; color: var(--gold-dark); flex-shrink: 0; margin-top: 1px; }
  .ec-label { font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.6; }

  /* ── Buttons ── */
  .btn-primary {
    background: var(--ink); color: var(--canvas);
    font-size: 11px; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 14px 28px;
    text-decoration: none; display: inline-block;
    transition: opacity 0.2s; font-family: var(--sans);
  }
  .btn-primary:hover { opacity: 0.75; }
  .btn-ghost {
    border: 1px solid var(--rule); color: var(--ink-mid);
    font-size: 11px; padding: 14px 28px; text-decoration: none;
    display: inline-block; font-family: var(--sans);
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover { border-color: var(--ink); color: var(--ink); }

  /* ── gold rule ── */
  .gold-rule { width: 32px; height: 2px; background: var(--gold); margin-bottom: 24px; }

  /* ── section labels ── */
  .section-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold-dark);
    margin-bottom: 16px; font-family: var(--sans);
  }
  .section-h2 {
    font-family: var(--serif);
    font-size: clamp(28px, 3.5vw, 48px); font-weight: 300; line-height: 1.12;
    color: var(--ink); margin-bottom: 24px;
  }
  .section-h2 em { font-style: italic; color: var(--gold-dark); }
  .section-body {
    font-size: 16px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.75; max-width: 600px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .product-hero-inner { grid-template-columns: 1fr; }
    .hero-right { display: none; }
    .modules-grid { grid-template-columns: repeat(2, 1fr); }
    .tier-item { grid-template-columns: 50px 1fr; }
    .tier-right { display: none; }
  }
  @media (max-width: 640px) {
    .modules-grid { grid-template-columns: 1fr; }
    .ethics-cards { grid-template-columns: 1fr; }
    .product-proof-strip { gap: 20px; }
  }
</style>
