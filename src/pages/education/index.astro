---
import PageLayout from '../../layouts/PageLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import CTABlock from '../../components/CTABlock.astro';

const products = [
  {
    id: '1F1-EDU-001',
    tier: 4,
    title: 'The A-Level Grade Gap System',
    body: 'Close the gap between your current grade and your target grade. Subject-specific diagnostics, technique drills, and a 30-day revision protocol — built for Year 12 and 13 students across all A-Level subjects.',
    price: '£47',
    href: '/education/a-level-grade-gap/',
    status: 'live' as const,
    featured: true,
  },
  {
    id: '1F1-EDU-001-T5',
    tier: 5,
    title: 'StudySystems — The SaaS Platform',
    body: 'The A-Level Grade Gap System running live at mystudysystem.ai. Progress saved automatically. Spaced repetition managed. Daily AI coach on Pro tier.',
    price: '£19/mo — £49/mo',
    href: 'https://mystudysystem.ai',
    status: 'building' as const,
    featured: false,
  },
  {
    id: '1F1-EDU-002',
    tier: 4,
    title: 'The GCSE Foundation System',
    body: 'The Grade Gap System adapted for GCSE. Subject-level diagnostics, command word mastery, and a structured 30-day protocol for Year 10 and 11 students.',
    href: '/education/',
    status: 'pipeline' as const,
    featured: false,
  },
  {
    id: '1F1-EDU-003',
    tier: 4,
    title: 'The University Application System',
    body: 'Personal statement architecture, subject-specific preparation, and interview readiness. For Year 13 students applying to Russell Group and competitive universities.',
    href: '/education/',
    status: 'pipeline' as const,
    featured: false,
  },
  {
    id: '1F1-EDU-004',
    tier: 3,
    title: 'The Teacher Intelligence Workflow',
    body: 'Marking, planning, and parent communication systems for secondary teachers. Reduce admin by 60%. Run on any AI model.',
    href: '/education/',
    status: 'pipeline' as const,
    featured: false,
  },
  {
    id: '1F1-EDU-005',
    tier: 5,
    title: 'The EdTech Operator Stack',
    body: 'For education businesses, tutoring platforms, and EdTech operators. Content engine, student success workflows, and institutional deployment.',
    href: '/education/',
    status: 'pipeline' as const,
    featured: false,
  },
];
---

<PageLayout
  title="Education Systems — SeedSystems™"
  description="SeedSystems™ Education builds AI-powered systems for A-Level students, GCSE learners, teachers, and EdTech operators. Ethics-cleared. Evidence-based. Built to close the grade gap."
  activePath="/education/"
>
  <!-- ── PAGE HERO ── -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">SeedSystems™</a>
        <span class="crumb-sep">→</span>
        <span>Education</span>
      </div>
      <div class="page-hero-inner">
        <div>
          <span class="page-hero-tag">Sector · Education</span>
          <h1 class="page-hero-h1">
            Education Systems.<br />
            <em>Built to close the gap.</em>
          </h1>
          <p class="page-hero-sub">
            From A-Level grade uplift to institutional learning design.
            Every SeedSystems™ Education product is evidence-based, ethics-cleared,
            and built with the 7-tier architecture — free entry point to fully managed operations.
          </p>
          <div class="page-hero-meta">
            <div class="meta-item">
              <span class="meta-num">1</span>
              <span class="meta-label">Product live</span>
            </div>
            <div class="meta-item">
              <span class="meta-num">5</span>
              <span class="meta-label">In pipeline</span>
            </div>
            <div class="meta-item">
              <span class="meta-num">16–18</span>
              <span class="meta-label">Primary user age</span>
            </div>
          </div>
        </div>
        <div class="page-hero-badge">
          <span class="tag tag-gold">Live Sector</span>
          <div class="hero-badge-stat">
            <span class="badge-n">97%</span>
            <span class="badge-l">Accuracy rate on<br />launch QA (18 scenarios)</span>
          </div>
          <div class="hero-badge-stat">
            <span class="badge-n">5.2×</span>
            <span class="badge-l">Conservative value<br />multiple vs price</span>
          </div>
          <div class="hero-badge-stat">
            <span class="badge-n">12/12</span>
            <span class="badge-l">Ethics clearance<br />questions passed</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── PRODUCTS ── -->
  <section class="products-section">
    <div class="container">
      <div class="products-intro">
        <p class="section-label">Products</p>
        <h2 class="section-h2">
          The Education System Stack
        </h2>
        <p class="section-body">
          Every product is assigned a product ID, built through the full 7-tier architecture,
          and tracked in version control. One product live. Five in pipeline.
        </p>
      </div>
      <div class="products-grid">
        {products.map(p => (
          <ProductCard {...p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── ICP ── -->
  <section class="icp-section">
    <div class="container">
      <div class="gold-rule"></div>
      <p class="section-label">Who It's For</p>
      <h2 class="section-h2">
        Three students.<br /><em>One system.</em>
      </h2>
      <div class="icp-grid">
        <div class="icp-card">
          <div class="icp-name">Hana, Y13, London</div>
          <div class="icp-desc">Predicted BBB, target AAB for medicine. Buys on TikTok recommendation. iPhone-first. Needs structure and daily progress.</div>
          <div class="icp-trigger">Upgrade trigger: friends say the AI coach gave instant essay feedback.</div>
        </div>
        <div class="icp-card">
          <div class="icp-name">Tariq, Y12, Dubai</div>
          <div class="icp-desc">Strong student, A* across three sciences. Parents invest in premium tools without hesitation. Needs depth on mark scheme logic.</div>
          <div class="icp-trigger">Upgrade trigger: wants AI to set his daily study schedule.</div>
        </div>
        <div class="icp-card">
          <div class="icp-name">Priya's daughter, Y12, Birmingham</div>
          <div class="icp-desc">Mum buys after seeing the free T1 guide. Needs something her daughter will actually stick to. Reassured by GDPR compliance.</div>
          <div class="icp-trigger">Upgrade trigger: daily reminders keep her daughter accountable.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <CTABlock
    eyebrow="Start now — it's free"
    headline="Get the free A-Level<br /><em>diagnostic prompt</em> pack."
    subtext="Tier 1 of the A-Level Grade Gap System. Free. No email required. Understand exactly where your marks are being lost in 20 minutes."
    primaryLabel="Download free guide"
    primaryHref="/education/a-level-grade-gap/"
    ghostLabel="See full system"
    ghostHref="/education/a-level-grade-gap/"
  />
</PageLayout>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    padding: 80px 0 72px;
    background: var(--canvas);
    border-bottom: 1px solid var(--rule);
  }
  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 400; color: var(--ink-light);
    letter-spacing: 0.04em; margin-bottom: 40px;
    font-family: var(--sans);
  }
  .breadcrumb a { color: var(--ink-light); text-decoration: none; transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--ink); }
  .crumb-sep { color: var(--rule); }
  .page-hero-inner {
    display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: start;
  }
  .page-hero-tag {
    display: inline-block; font-size: 10px; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold-dark); margin-bottom: 20px; font-family: var(--sans);
  }
  .page-hero-h1 {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 68px); font-weight: 300; line-height: 1.08;
    color: var(--ink); margin-bottom: 24px;
  }
  .page-hero-h1 em { font-style: italic; color: var(--gold-dark); }
  .page-hero-sub {
    font-size: 16px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.75; max-width: 560px; margin-bottom: 40px;
  }
  .page-hero-meta {
    display: flex; gap: 40px; flex-wrap: wrap;
    padding-top: 32px; border-top: 1px solid var(--rule);
  }
  .meta-item { display: flex; flex-direction: column; gap: 4px; }
  .meta-num {
    font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--ink);
  }
  .meta-label { font-size: 11px; font-weight: 300; color: var(--ink-light); }

  .page-hero-badge {
    background: var(--canvas-2); border: 1px solid var(--rule);
    padding: 28px; min-width: 220px;
    display: flex; flex-direction: column; gap: 24px;
  }
  .hero-badge-stat { display: flex; flex-direction: column; gap: 4px; }
  .badge-n {
    font-family: var(--serif); font-size: 30px; font-weight: 300; color: var(--ink);
  }
  .badge-l { font-size: 11px; font-weight: 300; color: var(--ink-light); line-height: 1.5; }

  /* ── PRODUCTS ── */
  .products-section { padding: 100px 0; background: var(--canvas); border-bottom: 1px solid var(--rule); }
  .products-intro { margin-bottom: 56px; }
  .products-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
    background: var(--rule); border: 1px solid var(--rule); overflow: hidden;
  }

  /* ── ICP ── */
  .icp-section { padding: 100px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .icp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; margin-top: 56px; }
  .icp-card { background: var(--white); padding: 32px; border: 1px solid var(--rule); }
  .icp-name {
    font-family: var(--serif); font-size: 18px; font-weight: 400;
    color: var(--ink); margin-bottom: 12px;
  }
  .icp-desc { font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.65; margin-bottom: 16px; }
  .icp-trigger {
    font-size: 11px; font-weight: 400; color: var(--gold-dark);
    letter-spacing: 0.02em; font-family: var(--sans);
  }

  /* Tags */
  .tag { display: inline-block; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; font-family: var(--sans); }
  .tag-gold { background: var(--gold); color: var(--ink); }

  @media (max-width: 900px) {
    .page-hero-inner { grid-template-columns: 1fr; }
    .page-hero-badge { display: none; }
    .products-grid { grid-template-columns: repeat(2, 1fr); }
    .icp-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .products-grid { grid-template-columns: 1fr; }
  }
</style>
