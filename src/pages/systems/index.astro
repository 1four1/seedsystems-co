---
import PageLayout from '../../layouts/PageLayout.astro';
import SystemCard from '../../components/SystemCard.astro';
import CTABlock from '../../components/CTABlock.astro';

const systems = [
  {
    id: 'SS-01',
    title: 'The Morning Intelligence System',
    tagline: '15 minutes · 10 prompts · Complete daily clarity',
    body: 'An AI-powered daily briefing built for decision-makers. Five intelligence layers — situation awareness, priority filtering, decision prep, opportunity scanning, and your compiled brief. Personalised to your role, industry, and priorities.',
    price: '$29',
    href: '/systems/morning-intelligence/',
    status: 'live' as const,
    layers: '5 intelligence layers',
    prompts: '10 master prompts',
  },
  {
    id: 'SS-02',
    title: 'Operations in a Box',
    tagline: 'Run your solo business like a firm',
    body: 'A complete AI-powered operational stack for freelancers and solo consultants. Proposals, client onboarding, project management, invoicing, scope protection, and weekly business reviews — all from prompts.',
    price: '$29',
    href: '/systems/operations-in-a-box/',
    status: 'live' as const,
    layers: '3 operational layers',
    prompts: '12 master prompts',
  },
  {
    id: 'SS-03',
    title: 'The Content Engine System',
    tagline: 'One insight → 30 days of content',
    body: 'Stop starting from blank every day. The Content Engine turns one insight into a month of platform-native content across LinkedIn, X, email, short-form video, and more. AI does the repurposing. You do the thinking.',
    price: '$29',
    href: '/systems/content-engine/',
    status: 'live' as const,
    layers: '4 content stages',
    prompts: '10 master prompts',
  },
  {
    id: 'SS-04',
    title: 'The Career Accelerator System',
    tagline: 'Stop waiting. Start engineering your career.',
    body: 'A complete AI-powered career management toolkit for ambitious professionals. Positioning language, LinkedIn optimisation, salary negotiation scripts, promotion frameworks, and interview preparation — all systematised.',
    price: '$29',
    href: '/systems/career-accelerator/',
    status: 'live' as const,
    layers: '5 career modules',
    prompts: '10 master prompts',
  },
  {
    id: 'SS-05',
    title: 'The Sales Intelligence System',
    tagline: 'Stop chasing leads. Start engineering pipeline.',
    body: 'A full-cycle AI sales system from ICP definition to closing. Account research, outreach, discovery, objection handling, follow-up sequences, and pipeline reporting — built for founders, freelancers, and account executives who sell.',
    price: '$29',
    href: '/systems/sales-intelligence/',
    status: 'live' as const,
    layers: '3 pipeline layers',
    prompts: '12 master prompts',
  },
  {
    id: 'SS-06',
    title: 'The Financial Planning System',
    tagline: 'Know your numbers. Own your decisions.',
    body: 'An AI-powered financial clarity system for founders, solos, and independent professionals. Cashflow modelling, scenario planning, pricing frameworks, financial review prompts, and investor-ready reporting logic.',
    price: '$29',
    href: '/systems/financial-planning/',
    status: 'building' as const,
    layers: '4 financial modules',
    prompts: '10 master prompts',
  },
  {
    id: 'SS-07',
    title: 'The Legal Document System',
    tagline: 'Protect yourself. Every engagement. Every time.',
    body: 'AI-powered contract, compliance, and legal communication system for independent professionals and small businesses. Template logic, clause libraries, scope protection frameworks, and dispute prevention prompts.',
    price: '$29',
    href: '/systems/legal-documents/',
    status: 'building' as const,
    layers: '3 legal layers',
    prompts: '10 master prompts',
  },
  {
    id: 'SS-08',
    title: 'The CEO Intelligence Briefing',
    tagline: 'Five modules. Built for how CEOs actually think.',
    body: 'Executive-grade AI intelligence across five CEO functions: strategic situation awareness, board and stakeholder management, competitive intelligence, leadership decision support, and weekly executive review. Not for everyone — built for the principal.',
    price: '$97',
    href: '/systems/ceo-intelligence/',
    status: 'live' as const,
    layers: '5 executive modules',
    prompts: '15 master prompts',
  },
  {
    id: 'SS-09',
    title: 'The Freelancer Command Center',
    tagline: 'Stop running your business from your inbox.',
    body: 'A complete operating system for independent professionals. Five modules: client management, pipeline and proposals, project operations, financial control, and contracts. AI does the heavy admin. You do the work that earns.',
    price: '$29',
    href: '/systems/freelancer-command-center/',
    status: 'live' as const,
    layers: '5 operational modules',
    prompts: '15 master prompts',
  },
];
---

<PageLayout
  title="Signature Systems — SeedSystems™"
  description="Nine curated AI systems built and used daily by the SeedSystems™ research and consulting team. From $29. Interactive HTML tools. All roles. All industries."
  activePath="/systems/"
>
  <!-- ── PAGE HERO ── -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">SeedSystems™</a>
        <span class="crumb-sep">→</span>
        <span>Signature Systems</span>
      </div>
      <div class="page-hero-inner">
        <div>
          <span class="page-hero-tag">SeedSystems™ Signature Systems</span>
          <h1 class="page-hero-h1">
            Nine systems.<br />
            <em>Built by practitioners.</em><br />
            Used daily.
          </h1>
          <p class="page-hero-sub">
            Every Signature System is built by our research and consulting team and used in our own work every day.
            Not theory. Not content. Working AI infrastructure — from morning intelligence to legal protection.
            Interactive HTML tools from $29. One-time purchase. No subscription.
          </p>
          <div class="page-hero-meta">
            <div class="meta-item">
              <span class="meta-num">9</span>
              <span class="meta-label">Systems in the series</span>
            </div>
            <div class="meta-item">
              <span class="meta-num">7</span>
              <span class="meta-label">Live now</span>
            </div>
            <div class="meta-item">
              <span class="meta-num">$29</span>
              <span class="meta-label">Entry price<br />one-time</span>
            </div>
          </div>
        </div>
        <div class="page-hero-badge">
          <div class="badge-eyebrow">What makes a Signature System</div>
          <div class="badge-row">
            <span class="badge-check">✓</span>
            <span>Built and used daily by our team</span>
          </div>
          <div class="badge-row">
            <span class="badge-check">✓</span>
            <span>First-principles methodology</span>
          </div>
          <div class="badge-row">
            <span class="badge-check">✓</span>
            <span>Ethics-cleared before launch</span>
          </div>
          <div class="badge-row">
            <span class="badge-check">✓</span>
            <span>Interactive HTML — no app needed</span>
          </div>
          <div class="badge-row">
            <span class="badge-check">✓</span>
            <span>Works with free Claude AI</span>
          </div>
          <div class="badge-row">
            <span class="badge-check">✓</span>
            <span>Personalised to your role instantly</span>
          </div>
          <div class="badge-row">
            <span class="badge-check">✓</span>
            <span>One-time purchase. Yours to keep.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── THESIS ── -->
  <section class="sig-thesis">
    <div class="container">
      <div class="thesis-inner">
        <div class="gold-rule"></div>
        <blockquote class="thesis-quote">
          "A system built by people who actually use it every day is
          a different object than a product built to sell.
          <strong>That's the only thing we build.</strong>"
        </blockquote>
        <p class="thesis-byline">The Signature Systems Standard</p>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── SYSTEMS GRID ── -->
  <section class="systems-section">
    <div class="container">
      <div class="systems-intro">
        <p class="section-label">The Nine Systems</p>
        <h2 class="section-h2">
          Pick the system<br /><em>you need today.</em>
        </h2>
        <p class="section-body">
          Each system is a standalone tool. Buy one. Buy all nine. Start with the free
          teaser on any live system and upgrade when you're ready.
        </p>
      </div>
      <div class="systems-grid">
        {systems.map(s => (
          <SystemCard {...s} />
        ))}
      </div>
    </div>
  </section>

  <hr class="rule" />

  <!-- ── HOW THEY WORK ── -->
  <section class="how-section">
    <div class="container">
      <div class="how-split">
        <div class="how-left">
          <div class="gold-rule"></div>
          <p class="section-label">How they work</p>
          <h2 class="section-h2">
            One file.<br /><em>Everything inside.</em>
          </h2>
          <p class="section-body">
            Every Signature System is a single interactive HTML file. Open it in your browser.
            Fill in your context once. Every prompt personalises instantly. Copy. Paste into Claude. Read your output.
          </p>
          <p class="section-body">
            No subscription. No login. No app. No ongoing cost. Claude is free at claude.ai — that's all you need.
            The system lives on your computer, runs anywhere, and is yours permanently.
          </p>
        </div>
        <div class="how-right">
          <div class="how-step">
            <div class="how-num">01</div>
            <div class="how-body">
              <div class="how-label">Open the file</div>
              <div class="how-desc">Double-click to open in any browser. No install. No account.</div>
            </div>
          </div>
          <div class="how-step">
            <div class="how-num">02</div>
            <div class="how-body">
              <div class="how-label">Fill in your context</div>
              <div class="how-desc">Your role, industry, priorities. One-time setup. All prompts update instantly.</div>
            </div>
          </div>
          <div class="how-step">
            <div class="how-num">03</div>
            <div class="how-body">
              <div class="how-label">Copy and paste</div>
              <div class="how-desc">One-click copy on every prompt. Paste into Claude. Free at claude.ai.</div>
            </div>
          </div>
          <div class="how-step">
            <div class="how-num">04</div>
            <div class="how-body">
              <div class="how-label">Read. Act. Repeat.</div>
              <div class="how-desc">Your AI output is tailored, structured, and ready to act on. Run the system daily.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <CTABlock
    eyebrow="Start free"
    headline="Try one prompt.<br /><em>Before you buy anything.</em>"
    subtext="Every live system has a free single-prompt teaser. No email. No sign-up. Open it in your browser and run it in Claude today."
    primaryLabel="Get the Morning Intelligence free prompt"
    primaryHref="https://seedsystems.gumroad.com/l/morning-intelligence-free"
    ghostLabel="See all systems"
    ghostHref="#systems"
  />
</PageLayout>

<style>
  /* ── PAGE HERO ── */
  .page-hero {
    padding: 80px 0 72px;
    background: var(--canvas);
    border-bottom: 1px solid var(--rule);
  }
  .breadcrumb {
    display: flex; align-items: center; gap: 10px;
    font-size: 11px; font-weight: 400; color: var(--ink-light);
    letter-spacing: 0.04em; margin-bottom: 40px; font-family: var(--sans);
  }
  .breadcrumb a { color: var(--ink-light); text-decoration: none; transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--ink); }
  .crumb-sep { color: var(--rule); }
  .page-hero-inner {
    display: grid; grid-template-columns: 1fr auto; gap: 64px; align-items: start;
  }
  .page-hero-tag {
    display: inline-block; font-size: 10px; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold-dark); margin-bottom: 20px; font-family: var(--sans);
  }
  .page-hero-h1 {
    font-family: var(--serif);
    font-size: clamp(36px, 5vw, 68px); font-weight: 300; line-height: 1.08;
    color: var(--ink); margin-bottom: 24px;
  }
  .page-hero-h1 em { font-style: italic; color: var(--gold-dark); }
  .page-hero-sub {
    font-size: 16px; font-weight: 300; color: var(--ink-mid);
    line-height: 1.75; max-width: 560px; margin-bottom: 40px;
  }
  .page-hero-meta {
    display: flex; gap: 40px; flex-wrap: wrap;
    padding-top: 32px; border-top: 1px solid var(--rule);
  }
  .meta-item { display: flex; flex-direction: column; gap: 4px; }
  .meta-num {
    font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--ink);
  }
  .meta-label { font-size: 11px; font-weight: 300; color: var(--ink-light); line-height: 1.5; }

  .page-hero-badge {
    background: var(--canvas-2); border: 1px solid var(--rule);
    padding: 28px; min-width: 240px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .badge-eyebrow {
    font-size: 10px; font-weight: 600; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gold-dark);
    font-family: var(--sans); margin-bottom: 4px;
  }
  .badge-row {
    display: flex; gap: 12px; align-items: flex-start;
    font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.5;
  }
  .badge-check { color: var(--gold-dark); font-family: var(--sans); flex-shrink: 0; font-weight: 500; }

  /* ── THESIS ── */
  .sig-thesis { padding: 80px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .thesis-inner { max-width: 760px; }
  .thesis-quote {
    font-family: var(--serif);
    font-size: clamp(20px, 2.5vw, 28px); font-weight: 300; font-style: italic;
    line-height: 1.55; color: var(--ink-mid); margin: 24px 0 24px;
  }
  .thesis-quote strong { font-style: normal; color: var(--ink); font-weight: 400; }
  .thesis-byline {
    font-size: 11px; font-weight: 500; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold-dark); font-family: var(--sans);
  }
  .gold-rule {
    width: 48px; height: 2px; background: var(--gold); margin-bottom: 28px;
  }

  /* ── SYSTEMS ── */
  .systems-section { padding: 100px 0; background: var(--canvas); border-bottom: 1px solid var(--rule); }
  .systems-intro { margin-bottom: 56px; max-width: 600px; }
  .systems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    overflow: hidden;
  }

  /* ── HOW ── */
  .how-section { padding: 100px 0; background: var(--canvas-2); border-bottom: 1px solid var(--rule); }
  .how-split {
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start;
  }
  .how-right { display: flex; flex-direction: column; gap: 0; }
  .how-step {
    display: grid; grid-template-columns: 48px 1fr;
    gap: 20px; align-items: start;
    padding: 24px 0; border-bottom: 1px solid var(--rule);
  }
  .how-step:first-child { border-top: 1px solid var(--rule); }
  .how-num {
    font-family: var(--serif); font-size: 28px; font-weight: 300;
    color: var(--gold-dark); line-height: 1;
  }
  .how-label {
    font-size: 14px; font-weight: 400; color: var(--ink); margin-bottom: 6px;
  }
  .how-desc {
    font-size: 13px; font-weight: 300; color: var(--ink-mid); line-height: 1.6;
  }

  /* ── Shared ── */
  .container {
    max-width: var(--container); margin: 0 auto; padding: 0 48px;
  }
  .section-label {
    font-size: 10px; font-weight: 600; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold-dark);
    font-family: var(--sans); margin-bottom: 16px;
    display: block;
  }
  .section-h2 {
    font-family: var(--serif);
    font-size: clamp(28px, 3.5vw, 48px); font-weight: 300; line-height: 1.12;
    color: var(--ink); margin-bottom: 20px;
  }
  .section-h2 em { font-style: italic; color: var(--gold-dark); }
  .section-body {
    font-size: 16px; font-weight: 300; color: var(--ink-mid); line-height: 1.75;
    margin-bottom: 16px;
  }
  .rule { border: none; border-top: 1px solid var(--rule); margin: 0; }

  @media (max-width: 1000px) {
    .systems-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 900px) {
    .page-hero-inner { grid-template-columns: 1fr; }
    .page-hero-badge { display: none; }
    .how-split { grid-template-columns: 1fr; gap: 48px; }
  }
  @media (max-width: 640px) {
    .systems-grid { grid-template-columns: 1fr; }
    .container { padding: 0 24px; }
    .page-hero-meta { gap: 24px; }
  }
</style>
